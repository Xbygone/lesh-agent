# ─── Lesh Agent yapılandırması (İSTEĞE BAĞLI) ───────────────────────
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# .env ASLA git'e commit edilmez (.gitignore korumasında).
#
# Hiçbir değer girmezseniz uygulama %100 YEREL modda çalışır:
# API anahtarlarınız makinenize özel üretilen bir anahtarla şifrelenip
# ~/.lesh/ altında saklanır. Bulut senkronizasyonu istiyorsanız doldurun.

# Supabase (bulut senkronizasyonu — isteğe bağlı)
SUPABASE_URL=
SUPABASE_KEY=

# Sabit şifreleme anahtarı (isteğe bağlı; boşsa makine başına otomatik üretilir)
# Üretmek için: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# release.py için GitHub PAT (sadece geliştirici/release süreci)
GITHUB_TOKEN=
