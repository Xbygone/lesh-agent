# --- Lesh Agent configuration (OPTIONAL) ---------------------------
# Copy this file as .env:  cp .env.example .env
# .env is NEVER committed to git (protected by .gitignore).
#
# If you leave everything empty the app runs 100% LOCALLY:
# your API keys are encrypted with a per-machine key generated on
# first run and stored under ~/.lesh/. Fill these in only if you
# want cloud sync.

# Supabase (cloud sync — optional)
SUPABASE_URL=
SUPABASE_KEY=

# Fixed encryption key (optional; auto-generated per machine when empty)
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# GitHub PAT for release scripts (developers/publishing only)
GITHUB_TOKEN=
